<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)serilog\4.3.1\buildTransitive\Serilog.targets" Condition="Exists('$(NuGetPackageRoot)serilog\4.3.1\buildTransitive\Serilog.targets')" />
    <Import Project="$(NuGetPackageRoot)riok.mapperly\4.3.1\build\Riok.Mapperly.targets" Condition="Exists('$(NuGetPackageRoot)riok.mapperly\4.3.1\build\Riok.Mapperly.targets')" />
    <Import Project="$(NuGetPackageRoot)refit\10.0.1\buildTransitive\netstandard2.0\refit.targets" Condition="Exists('$(NuGetPackageRoot)refit\10.0.1\buildTransitive\netstandard2.0\refit.targets')" />
    <Import Project="$(NuGetPackageRoot)nswag.aspnetcore\14.6.3\build\NSwag.AspNetCore.targets" Condition="Exists('$(NuGetPackageRoot)nswag.aspnetcore\14.6.3\build\NSwag.AspNetCore.targets')" />
    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.2\build\Microsoft.AspNetCore.OpenApi.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.2\build\Microsoft.AspNetCore.OpenApi.targets')" />
  </ImportGroup>
</Project>